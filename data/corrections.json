{
  "_version": 7,
  "rules": [
    {
      "id": "double-space",
      "find": "  ",
      "replace": " "
    },
    {
      "id": "space-before-period",
      "find": " .",
      "replace": "."
    },
    {
      "id": "double-period",
      "find": "..",
      "replace": "."
    },
    {
      "id": "comma-space-fix",
      "find": " ,",
      "replace": ","
    }
  ]
}
